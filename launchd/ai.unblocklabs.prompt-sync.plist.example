<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.unblocklabs.prompt-sync</string>
  <key>ProgramArguments</key>
  <array>
    <string>__SYNC_SCRIPT__</string>
    <string>__WORKSPACE__</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>StandardOutPath</key>
  <string>__LOG_DIR__/prompt-sync.log</string>
  <key>StandardErrorPath</key>
  <string>__LOG_DIR__/prompt-sync.error.log</string>
</dict>
</plist>
